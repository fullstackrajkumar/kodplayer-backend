{
  "name": "@mbt/admin-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec \"ts-node --transpile-only src/main.ts\"",
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "migrate:up": "LOCAL=true npx ts-node -r tsconfig-paths/register src/dbops/changelog/index.ts up",
    "seed:admin": "LOCAL=true npx ts-node -r tsconfig-paths/register src/dbops/seed-admin.ts",
    "lint": "echo \"(no eslint yet)\""
  },
  "dependencies": {
    "@mbt/api-common": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.4.7",
    "mongodb": "^6.12.0",
    "mongoose": "^8.10.2",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/multer": "^1.4.12",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "mongo-migrate-ts": "^2.0.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2"
  }
}
