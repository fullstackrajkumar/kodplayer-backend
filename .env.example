# Copy to repo root as `.env` (services load `../../.env` first).
# Production: copy values, then `pnpm build && pnpm start:pm2`
# Nginx: deploy/nginx-mbt.conf.example

NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/your-app-name

# api-service (dev: 8080 / turbo dev:api; PM2 prod: 4040)
PORT=4040

# admin-service (dev: 8081; PM2 prod: 4041)
ADMIN_PORT=4041
ADMIN_SERVICE_URL=http://127.0.0.1:4041
ADMIN_REALTIME_API_KEY=dev-admin-realtime-api-key
JWT_SECRET=change-me-in-production
APP_JWT_SECRET=change-me-in-production
GCS_BUCKET_NAME=your-app-name
GCS_SA_KEY_JSON=

# Invoices (optional; used by webhook-service on payment success)
INVOICE_LOGO_URL=
INVOICE_STORE_NAME=Your App Name

# payment (checkout + webhooks) — enable when you add orders module
PAYMENT_GATEWAY=RAZORPAY
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# webhook-service (dev: 8083; PM2 prod: 4043)
WEBHOOK_PORT=4043
WEBHOOK_SERVICE_URL=http://127.0.0.1:4043

MONGOOSE_SYNC_INDEXES=true

# notification-service (dev: 8082; PM2 prod: 4042)
NOTIFICATION_PORT=4042
REDIS_URL=redis://127.0.0.1:6379
NOTIFICATION_SERVICE_API_KEY=dev-notification-api-key
NOTIFICATION_SERVICE_URL=http://127.0.0.1:4042
FIREBASE_SERVICE_ACCOUNT_JSON=
